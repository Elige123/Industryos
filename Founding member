<style>
:root{--black:#080808;--deep:#0f0f0f;--surface:#161616;--border:#2a2a2a;--gold:#C9A84C;--gold-light:#E8C97A;--gold-dim:rgba(201,168,76,0.13);--white:#F5F0E8;--muted:#888880}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--white);font-family:'Instrument Sans',sans-serif;overflow-x:hidden;min-height:100vh}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.4}

nav{display:flex;align-items:center;justify-content:space-between;padding:1.4rem 3rem;border-bottom:1px solid var(--border);background:rgba(8,8,8,.95);position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)}
.nav-logo{font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);text-decoration:none}
.nav-back{font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s}
.nav-back:hover{color:var(--white)}
.nav-back::before{content:'← '}

/* HERO */
.founding-hero{padding:6rem 3rem 4rem;text-align:center;position:relative;overflow:hidden;border-bottom:1px solid var(--border)}
.founding-hero::before{content:'';position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,.08) 0,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.scarcity-bar{display:inline-flex;align-items:center;gap:.8rem;font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);background:var(--gold-dim);border:1px solid rgba(201,168,76,.3);padding:.5rem 1.2rem;margin-bottom:2rem;position:relative}
.scarcity-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:blink 1.5s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.founding-hero h1{font-family:'Playfair Display',serif;font-size:clamp(3rem,6vw,6.5rem);font-weight:900;line-height:.92;margin-bottom:1.5rem;position:relative}
.founding-hero h1 em{font-style:italic;color:var(--gold)}
.founding-hero p{color:var(--muted);font-size:1.05rem;max-width:46ch;margin:0 auto;line-height:1.75;position:relative}

/* SPOTS COUNTER */
.spots-wrap{display:flex;justify-content:center;margin:3rem 0 0;position:relative}
.spots-card{background:var(--surface);border:1px solid var(--border);padding:2rem 4rem;text-align:center;position:relative;overflow:hidden}
.spots-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.spots-num{font-family:'Playfair Display',serif;font-size:4rem;font-weight:900;color:var(--gold);line-height:1}
.spots-label{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-top:.4rem}
.spots-bar-wrap{width:200px;height:4px;background:var(--border);margin:.8rem auto 0;border-radius:2px;overflow:hidden}
.spots-bar{height:100%;background:var(--gold);width:14%;border-radius:2px;transition:width 1s ease}

/* MAIN LAYOUT */
.main-layout{display:grid;grid-template-columns:1fr 420px;gap:0;max-width:1100px;margin:5rem auto;padding:0 3rem}

/* WHAT YOU GET */
.what-you-get h2{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;margin-bottom:.5rem}
.what-you-get h2 em{font-style:italic;color:var(--gold)}
.section-sub{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:3rem}

.benefit-list{display:flex;flex-direction:column;gap:0;border:1px solid var(--border)}
.benefit{display:flex;align-items:flex-start;gap:1.5rem;padding:1.8rem 2rem;border-bottom:1px solid var(--border);transition:background .2s}
.benefit:last-child{border-bottom:none}
.benefit:hover{background:var(--surface)}
.benefit-icon{font-size:1.4rem;flex-shrink:0;padding-top:.1rem}
.benefit-text strong{display:block;font-family:'Instrument Sans',sans-serif;font-weight:600;font-size:1rem;margin-bottom:.3rem}
.benefit-text span{font-size:.88rem;color:var(--muted);line-height:1.6}

.compare{margin-top:3rem;border:1px solid var(--border)}
.compare-header{display:grid;grid-template-columns:1fr 1fr 1fr;background:var(--surface);border-bottom:1px solid var(--border)}
.compare-col{padding:1rem 1.5rem;font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);text-align:center}
.compare-col.highlight{color:var(--gold)}
.compare-row{display:grid;grid-template-columns:1fr 1fr 1fr;border-bottom:1px solid var(--border)}
.compare-row:last-child{border-bottom:none}
.compare-cell{padding:1rem 1.5rem;font-size:.88rem;text-align:center;color:var(--muted);display:flex;align-items:center;justify-content:center}
.compare-cell.feature-name{text-align:left;justify-content:flex-start;color:var(--white);font-size:.85rem}
.compare-cell.yes{color:var(--gold)}
.compare-cell.no{color:#444}

/* PAYMENT CARD */
.payment-card{background:var(--surface);border:1px solid var(--border);padding:2.5rem;position:sticky;top:6rem;align-self:start;position:relative;overflow:hidden}
.payment-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--gold-light),var(--gold))}
.plan-badge{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--black);background:var(--gold);padding:.3rem .8rem;display:inline-block;margin-bottom:1.5rem;font-weight:500}
.price-display{margin-bottom:.4rem}
.price-big{font-family:'Playfair Display',serif;font-size:4rem;font-weight:900;line-height:1}
.price-big sup{font-size:1.5rem;vertical-align:super;color:var(--gold)}
.price-note{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.3rem}
.price-strike{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.1em;color:var(--muted);text-decoration:line-through;margin-bottom:2rem}
.price-strike strong{color:#555}

.plan-features{list-style:none;margin-bottom:2rem;border-top:1px solid var(--border);padding-top:1.5rem}
.plan-features li{font-size:.9rem;color:var(--muted);padding:.55rem 0;border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:center;gap:.8rem}
.plan-features li::before{content:'✓';color:var(--gold);font-family:'DM Mono',monospace;font-size:.75rem;font-weight:500}

/* STRIPE FORM */
.form-field{margin-bottom:1.2rem}
.form-field label{display:block;font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.5rem}
.form-field input{width:100%;background:var(--black);border:1px solid var(--border);color:var(--white);font-family:'Instrument Sans',sans-serif;font-size:.92rem;padding:.8rem 1rem;outline:none;transition:border-color .2s}
.form-field input:focus{border-color:var(--gold)}
.form-field input::placeholder{color:#444}
.card-row{display:grid;grid-template-columns:1fr 1fr;gap:.8rem}

/* Stripe element container */
#card-element{background:var(--black);border:1px solid var(--border);padding:.85rem 1rem;transition:border-color .2s}
#card-element.focused{border-color:var(--gold)}

.pay-btn{width:100%;font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;font-weight:500;background:var(--gold);color:var(--black);border:none;padding:1.1rem;cursor:pointer;transition:all .2s;margin-top:.8rem;position:relative}
.pay-btn:hover:not(:disabled){background:var(--gold-light)}
.pay-btn:disabled{opacity:.5;cursor:not-allowed}
.pay-guarantee{font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-align:center;margin-top:.8rem}
.pay-error{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.08em;color:#FF4D2E;margin-top:.6rem;display:none}

/* SUCCESS */
.success-state{display:none;text-align:center;padding:2rem 0}
.success-icon{font-size:3rem;margin-bottom:1rem}
.success-state h3{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;margin-bottom:.8rem}
.success-state h3 em{font-style:italic;color:var(--gold)}
.success-state p{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.1em;color:var(--muted);line-height:1.8}

/* STRIPE NOTE */
.stripe-note{display:flex;align-items:center;justify-content:center;gap:.5rem;font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:1rem}
.stripe-note::before{content:'🔒';font-size:.75rem}

/* TESTIMONIAL STYLE SOCIAL PROOF */
.social-proof{margin-top:5rem;padding:0 3rem;max-width:1100px;margin-left:auto;margin-right:auto}
.proof-label{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:2rem;display:flex;align-items:center;gap:1rem}
.proof-label::after{content:'';flex:1;max-width:50px;height:1px;background:var(--gold);opacity:.5}
.proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border)}
.proof-card{background:var(--deep);padding:2rem;transition:background .2s}
.proof-card:hover{background:var(--surface)}
.proof-quote{font-family:'Playfair Display',serif;font-style:italic;font-size:1.05rem;line-height:1.6;margin-bottom:1.2rem}
.proof-who{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
.proof-who strong{color:var(--gold);display:block;margin-bottom:.2rem}

footer{border-top:1px solid var(--border);padding:2.5rem 3rem;display:flex;justify-content:space-between;align-items:center;background:var(--deep);margin-top:5rem}
.footer-logo{font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.footer-copy{font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.1em;color:var(--muted)}

@media(max-width:900px){
  nav{padding:1.2rem 1.5rem}
  .founding-hero{padding:4rem 1.5rem 3rem}
  .main-layout{grid-template-columns:1fr;padding:0 1.5rem;margin:3rem auto}
  .payment-card{position:static}
  .proof-grid{grid-template-columns:1fr}
  .social-proof{padding:0 1.5rem}
  footer{flex-direction:column;gap:1.2rem;text-align:center}
}
</style>
</head>
