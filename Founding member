<script>
// ─── SPOTS COUNTER ANIMATION ───
window.addEventListener('load', () => {
  setTimeout(() => {
    const bar = document.getElementById('spots-bar');
    if(bar) bar.style.width = '13.8%'; // 69 of 500 taken
  }, 500);
});

// ─── STRIPE SETUP ───
// Replace with your actual Stripe publishable key
// Get it from: https://dashboard.stripe.com/apikeys
const STRIPE_KEY = 'pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE';

let stripe, elements, cardElement;

function initStripe() {
  if (STRIPE_KEY.includes('YOUR_STRIPE')) {
    // Demo mode - show mock form
    document.getElementById('card-element').innerHTML = `
      <div style="display:grid;gap:.6rem">
        <input style="background:var(--black);border:1px solid var(--border);color:var(--white);font-family:'Instrument Sans',sans-serif;font-size:.92rem;padding:.7rem 1rem;outline:none;width:100%" placeholder="Card number" type="text" maxlength="19" oninput="this.value=this.value.replace(/[^0-9]/g,'').replace(/(.{4})/g,'$1 ').trim()"/>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.6rem">
          <input style="background:var(--black);border:1px solid var(--border);color:var(--white);font-family:'Instrument Sans',sans-serif;font-size:.92rem;padding:.7rem 1rem;outline:none" placeholder="MM / YY" type="text" maxlength="7"/>
          <input style="background:var(--black);border:1px solid var(--border);color:var(--white);font-family:'Instrument Sans',sans-serif;font-size:.92rem;padding:.7rem 1rem;outline:none" placeholder="CVC" type="text" maxlength="4"/>
        </div>
      </div>`;
    return;
  }
  stripe = Stripe(STRIPE_KEY);
  elements = stripe.elements({
    appearance: {
      theme: 'night',
      variables: { colorPrimary: '#C9A84C', colorBackground: '#080808', colorText: '#F5F0E8', colorDanger: '#FF4D2E', fontFamily: 'Instrument Sans, sans-serif', borderRadius: '0px' }
    }
  });
  cardElement = elements.create('card', { hidePostalCode: false });
  cardElement.mount('#card-element');
  cardElement.on('focus', () => document.getElementById('card-element').classList.add('focused'));
  cardElement.on('blur', () => document.getElementById('card-element').classList.remove('focused'));
}

initStripe();

// ─── HANDLE PAYMENT ───
async function handlePayment() {
  const name = document.getElementById('pay-name').value.trim();
  const email = document.getElementById('pay-email').value.trim();
  const artist = document.getElementById('pay-artist').value.trim();
  const errEl = document.getElementById('pay-error');
  const btn = document.getElementById('pay-btn');

  errEl.style.display = 'none';

  if (!name || !email || !artist) {
    errEl.textContent = 'Please fill in all fields above.';
    errEl.style.display = 'block';
    return;
  }
  if (!email.includes('@')) {
    errEl.textContent = 'Please enter a valid email.';
    errEl.style.display = 'block';
    return;
  }

  // DEMO MODE (no Stripe key yet)
  if (STRIPE_KEY.includes('YOUR_STRIPE')) {
    btn.disabled = true;
    btn.textContent = 'Processing...';
    await new Promise(r => setTimeout(r, 2000));
    showSuccess(name, email, artist);
    return;
  }

  // REAL STRIPE FLOW
  // You'll need a backend endpoint to create a PaymentIntent or Subscription
  // See SETUP-PAYMENTS.md for instructions
  btn.disabled = true;
  btn.textContent = 'Processing...';

  try {
    // 1. Call your backend to create a subscription/payment intent
    // const res = await fetch('/api/create-subscription', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({name,email,artist}) });
    // const { clientSecret } = await res.json();

    // 2. Confirm card payment
    // const result = await stripe.confirmCardPayment(clientSecret, { payment_method: { card: cardElement, billing_details: { name, email } } });
    // if (result.error) throw new Error(result.error.message);

    showSuccess(name, email, artist);
  } catch(err) {
    errEl.textContent = err.message;
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Become a Founding Member →';
  }
}

function showSuccess(name, email, artist) {
  document.getElementById('payment-form').style.display = 'none';
  document.getElementById('success-state').style.display = 'block';
  // Update spots
  const spotsEl = document.getElementById('spots-remaining');
  if(spotsEl) { const n = parseInt(spotsEl.textContent) - 1; spotsEl.textContent = n; }
  // Save locally
  const members = JSON.parse(localStorage.getItem('ios_members') || '[]');
  members.push({name, email, artist, date: new Date().toISOString()});
  localStorage.setItem('ios_members', JSON.stringify(members));
  document.getElementById('member-num').textContent = 69 + members.length;
}
</script>
